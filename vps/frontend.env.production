# ═══════════════════════════════════════════════════════════════════
#  iaDoS — Frontend Next.js  (VPS)
#  Renombrar a .env.local y subir al VPS en: /opt/iados/frontend/.env.local
# ═══════════════════════════════════════════════════════════════════

# URL del backend (server-side, sin exponer al navegador)
API_URL=http://localhost:3001/api

# URL del backend (expuesta al navegador — misma IP que el VPS)
NEXT_PUBLIC_API_URL=http://TU_IP_VPS:3001/api
